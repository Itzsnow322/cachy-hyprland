{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",

  "control-center-width": 380,
  "control-center-height": 800,

  "notification-window-width": 340,
  "notification-icon-size": 42,

  "notification-body-image-height": 140,
  "notification-body-image-width": 220,

  "timeout": 6,
  "timeout-low": 4,
  "timeout-critical": 0,

  "fit-to-screen": true,

  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": " Control Center",
      "clear-all-button": true,
      "button-text": "Clear"
    },

    "dnd": {
      "text": "🌙 Do Not Disturb"
    },

    "mpris": {
      "image-size": 100,
      "image-radius": 20
    },

    "volume": {
      "label": "🔊 Volume"
    },

    "notifications": {
      "show-less-than": 5
    }
  }
}
